---
// Custom Header override — wraps Starlight's default and slots in a
// top-nav "Docs" link next to the site title. The default header
// only exposes `social:` icons (GitHub) + the sidebar, which doesn't
// give you a plain prose link up top.
import Default from '@astrojs/starlight/components/Header.astro';
---

<div class="honker-header-wrapper">
  <Default><slot /></Default>
  <nav class="honker-top-nav" aria-label="Top">
    <a href="/docs/">Docs</a>
  </nav>
</div>

<style>
  .honker-header-wrapper {
    display: contents;
  }
  .honker-top-nav {
    position: absolute;
    top: 0;
    right: var(--sl-nav-pad-x, 1rem);
    height: var(--sl-nav-height);
    display: flex;
    align-items: center;
    gap: 1rem;
    /* Sit above Starlight's GitHub icon by offsetting left of it. */
    padding-right: 3rem;
    pointer-events: none;
  }
  .honker-top-nav a {
    pointer-events: auto;
    color: var(--sl-color-text);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
  .honker-top-nav a:hover {
    color: var(--sl-color-accent-high);
    background: var(--sl-color-gray-6);
  }
  @media (max-width: 50rem) {
    /* Mobile nav: Starlight hides title + shows hamburger;
       tuck our Docs link into the sidebar instead. */
    .honker-top-nav { display: none; }
  }
</style>
